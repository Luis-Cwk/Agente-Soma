# SomaAgent — Environment Variables
# Copy this to .env and fill in your values

# Ollama Cloud API
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=sk-synth-your-key-here
OLLAMA_MODEL=glm-5
# Other available models on this endpoint:
# glm-5 (recommended — fast + great JSON)
# gemma3:12b (balanced)
# ministral-3:14b (fast)
# qwen3.5:397b (max power, slower)

# Pinata IPFS
PINATA_API_KEY=your-pinata-key
PINATA_SECRET_KEY=your-pinata-secret

# Base Blockchain (NFT)
BASE_RPC_URL=https://mainnet.base.org
WALLET_PRIVATE_KEY=your-wallet-private-key
NFT_CONTRACT_ADDRESS=your-contract-address

# Auctions (RARE Protocol / SuperRare on Base)
AUCTION_ENABLED=false
AUCTION_STARTING_PRICE_ETH=0.05
AUCTION_DURATION_SECONDS=86400
SUPERRARE_BAZAAR_ADDRESS=0x51c36ffb05e17ed80ee5c02fa83d7677c5613de2

# Agent Config
AGENT_NAME=SomaAgent
AGENT_VERSION=2.0.0
LOG_DIR=logs
